<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>TaskFlow Portal</display-name>

    <!-- SPA Routing Filter to support HTML5 routing -->
    <filter>
        <filter-name>SpaFilter</filter-name>
        <filter-class>com.rapidx.taskflow.filter.SpaFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SpaFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Task API Servlet -->
    <servlet>
        <servlet-name>TaskApiServlet</servlet-name>
        <servlet-class>com.rapidx.taskflow.servlet.TaskApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TaskApiServlet</servlet-name>
        <url-pattern>/api/tasks</url-pattern>
        <url-pattern>/api/tasks/*</url-pattern>
    </servlet-mapping>

    <!-- System API Servlet -->
    <servlet>
        <servlet-name>SystemApiServlet</servlet-name>
        <servlet-class>com.rapidx.taskflow.servlet.SystemApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SystemApiServlet</servlet-name>
        <url-pattern>/api/system</url-pattern>
        <url-pattern>/api/system/*</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
</web-app>
